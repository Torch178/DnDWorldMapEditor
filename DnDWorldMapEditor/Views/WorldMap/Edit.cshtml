@model DnDWorldMapEditor.ViewModels.WorldMapEditViewModel

@{
    ViewData["Title"] = "Edit";
}

@{ await Html.RenderPartialAsync("HeaderComponent", "Edit World Map");}
<div class="container-fluid justify-content-center ">
    <div class="card">
        <h4 class="card-header">World Map Info</h4>
        <div class="row  card-body">
            <div class="col-md-4 m-2 p-3 ">
                <form asp-action="Edit" enctype="multipart/form-data" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
                    <div class="form-group m-2">
                        <label asp-for="Name" class="control-label"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="form-group m-2">
                        <label asp-for="Description" class="control-label"></label>
                        <textarea asp-for="Description" class="form-control overflow-y-scroll" >@Model.Description</textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                    <div class="form-group m-2">
                        <label asp-for="NewImage" class="control-label"></label>
                        <input asp-for="NewImage" type="file" class="form-control" accept="image/png, image/jpg, image/jpeg, image/svg" />
                        <span asp-validation-for="NewImage" class="text-danger"></span>
                    </div>
                    <div class="form-group m-2">
                        <input type="submit" value="Save" class="btn btn-primary" />
                    </div>
                </form>
            </div>
        </div>
    </div>
    
</div>

