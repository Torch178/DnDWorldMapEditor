@model DnDWorldMapEditor.Models.WorldMap
@{
    ViewData["Title"] = "Details";
    int mapSize = 500;
    
}
<style>
    .worldMapGridArea{
        background-image: url("/images/worldMaps/@Model.BackgroundImage");
        background-repeat: no-repeat;
        background-position: center center;
        background-size: cover;
        height: 500px;
        width: 500px;
    }
    .col{
        column-height: calc((@mapSize / @(Model.TotalRows) * 1px) - 1px);
        border: 1px solid black;
        
    }
   .map-row{
       width: 500px;
   }
    
</style>

<h1>Details</h1>

<div>
    <h4>WorldMap</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.UserId)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.UserId)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.TotalRows)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.TotalRows)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.TotalColumns)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.TotalColumns)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.BackgroundImage)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.BackgroundImage)
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>

<div class="container worldMapGridArea">
    @{
        for (int i = 0; i < Model.TotalRows; i++)
        {
            <div class="row map-row" style="flex-wrap: nowrap">
                @for (int j = 0; j < Model.TotalColumns; j++)
                { 
                    <div
                        class="col gridSpace align-content-center"
                        onclick="loadPopup(@i,@j,@Model.Id)">
                        X
                    </div>
                    
                }
            </div>
        }
    }
</div>


<!-- Empty Modal Container -->
<div id="myModal" class="modal fade" role="dialog">
    <div class="modal-dialog">
        <div class="modal-content" id="modalContent">
            <!-- Partial View content will be injected here -->
        </div>
    </div>
</div>

<script type="text/javascript">
    function loadPopup(row, col, id){
        $.ajax({
            url: "/WorldMap/GetDetails",
            type: 'GET',
            data: {row: row, col: col, worldMapId: id},
            success: function(data){
                $('#modalContent').html(data);
                $('#myModal').modal('show');
            },
            error: function(){
                alert("Error loading content.");
            }
        });
    }
</script>
