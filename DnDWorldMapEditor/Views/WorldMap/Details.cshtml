@model DnDWorldMapEditor.ViewModels.WorldMapDetailsViewModel

@{
    ViewData["Title"] = "Details";
    int mapSize = 500;
    
}
<style>
    .worldMapGridArea{
        background-image: url("/images/worldMaps/@Model.WorldMap.BackgroundImage");
        background-repeat: no-repeat;
        background-position: center center;
        background-size: cover;
        height: 500px;
        width: 500px;
    }
    .col{
        column-height: calc((@mapSize / @(Model.WorldMap.TotalRows) * 1px) - 1px);
        border: 1px solid black;
        
    }
   .map-row{
       width: 500px;
   }
    
</style>

<h1>Details</h1>

<div>
    <h4>WorldMap</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.WorldMap.UserId)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.WorldMap.UserId)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.WorldMap.Name)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.WorldMap.Name)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.WorldMap.Description)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.WorldMap.Description)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.WorldMap.TotalRows)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.WorldMap.TotalRows)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.WorldMap.TotalColumns)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.WorldMap.TotalColumns)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.WorldMap.BackgroundImage)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.WorldMap.BackgroundImage)
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.WorldMap.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>

<div class="container worldMapGridArea">
    @{
        for (int i = 0; i < Model.WorldMap.TotalRows; i++)
        {
            <div class="row map-row" style="flex-wrap: nowrap">
                @for (int j = 0; j < Model.WorldMap.TotalColumns; j++)
                {
                    <div class="col justify-content-center">!</div>
                }
            </div>
        }
    }
</div>
