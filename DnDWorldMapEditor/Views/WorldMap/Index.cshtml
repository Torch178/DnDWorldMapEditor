@model IEnumerable<DnDWorldMapEditor.Models.WorldMap>

@{
    ViewData["Title"] = "Index";
}
@using X.PagedList.Mvc.Core;
@using X.PagedList;


<h1>World Maps</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</p>

<div class="row row-cols-md-3 row-cols-1 g-3">

    @{
        foreach (var map in ViewBag.pageOfItems)
        {
            <partial name="WorldMapIndexCard" model="map"/>
        }
    }
</div>
<partial name="PaginationControls"/>

