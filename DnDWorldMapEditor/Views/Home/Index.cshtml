@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1>DnD World Map Editor</h1>
    @if (SignInManager.IsSignedIn(User))
    {
        <h3 class="display-4">Welcome @User.Identity?.Name</h3>
        <div class="container mt-3">
            <div class=" row row-cols-md-3 row-cols-1 g-3">
                <div class="col">
                    <div class="card dashboard-card w-auto col-3">
                        <h5 class="card-header">Worlds</h5>
                        <div class="card-body">
                            <p class="card-text dashboard-card-text">Explore an existing World or create a new one!</p>
                            <div class="d-flex justify-content-evenly">
                                <a asp-controller="WorldMap" asp-action="Create" class=" btn btn-primary ">Create World</a>
                                <a asp-controller="WorldMap" asp-action="Index" class="btn btn-primary">View Worlds</a>
                            </div>
                            
                        </div>
                    </div>
                </div>
                <div class="col">
                    <div class="dashboard-card card w-auto col-3">
                        <h5 class="card-header">Encounters</h5>
                        <div class="card-body">
                            <p class="card-text dashboard-card-text">Create and manage thrilling Encounters to populate your world with!</p>
                            <div class="d-flex  justify-content-evenly ">
                                <a asp-controller="Encounter" asp-action="Create" class="btn btn-primary">Create
                                    Encounter</a>
                                <a asp-controller="Encounter" asp-action="Index" class="btn btn-primary">View Encounters</a>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col">
                    <div class=" dashboard-card card w-auto col-3">
                        <h5 class="card-header">Characters</h5>
                        <div class="card-body">
                            <p class="card-text dashboard-card-text">With supporting text below as a natural lead-in to additional
                                content.</p>
                            <div class="d-flex  justify-content-evenly ">
                                <a asp-controller="Character" asp-action="Create" class="btn btn-primary">Create
                                    Character</a>
                                <a asp-controller="Character" asp-action="Index" class="btn btn-primary">View Characters</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <h3 class="display-4">Welcome, Please <a asp-area="Identity" asp-page="/Account/Login">Login</a>
            or <a asp-area="Identity" asp-page="/Account/Register">Register</a></h3>
    }


</div>