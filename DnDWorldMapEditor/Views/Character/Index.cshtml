@model IEnumerable<DnDWorldMapEditor.Models.Character>

@{
    ViewData["Title"] = "Index";
}
@using X.PagedList.Mvc.Core;
@using X.PagedList;

<h1>Characters</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</p>

<div class="row row-cols-md-3 row-cols-1 g-3">

    @{
        foreach (var character in ViewBag.pageOfItems)
        {
            <partial name="CharacterIndexCard" model="character"/>
        }
    }
</div>
<partial name="PaginationControls"/>