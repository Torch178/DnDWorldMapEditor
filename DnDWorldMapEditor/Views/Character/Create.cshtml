@model DnDWorldMapEditor.Models.Character

@{
    ViewData["Title"] = "Create";
}
<div class="container ">
    <a asp-action="Index" class="rounded float-start"><h3>
        <img src="~/images/Icons/arrow-left-square-fill.svg" width="32" height="32"
             fill="white" class="bi bi-arrow-left-square-fill rounded bg-white"/>
    </h3></a>
    <h1 class=" d-flex justify-content-center">Create Character</h1>

</div>

<div class="container-fluid justify-content-center ">
    <div class="card">
        <h4 class="card-header">Character Info</h4>
        <div class="row  card-body">
            <div class="col-md-4 m-2 p-3 ">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="form-group m-2">
                        <label asp-for="Name" class="control-label"></label>
                        <input asp-for="Name" class="form-control"/>
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="form-group m-2">
                        <label asp-for="Description" class="control-label"></label>
                        <input asp-for="Description" class="form-control"/>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                    <div class="form-group m-2">
                        <input type="submit" value="Create" class="btn btn-primary"/>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
</div>


