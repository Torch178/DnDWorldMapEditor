@model DnDWorldMapEditor.ViewModels.GridSpaceDetailsViewModel
@{
    string accessibilityStatus = "";
}

<div class="modal-header">
    <h5 class="modal-title">Item Details</h5>
    <button type="button" class="close" data-bs-dismiss="modal">&times;</button>
</div>

<ul class="nav nav-tabs" id="tabContent">
    <li class="nav-item"><a aria-selected="True" class="nav-link active" href="#details"
                            data-bs-toggle="tab">General</a></li>
    <li class="nav-item"><a class="nav-link" href="#history" data-bs-toggle="tab">History</a></li>
    <li class="nav-item"><a class="nav-link" href="#notes" data-bs-toggle="tab">Notes</a></li>
    <li class="nav-item"><a class="nav-link" href="#encounters" data-bs-toggle="tab">Encounters</a></li>
    <li class="nav-item"><a class="nav-link" href="#characters" data-bs-toggle="tab">Characters</a></li>
</ul>



<div class="modal-body">
    <div class="tab-content">
        <div class="tab-pane active show" id="details">
            <h6>General Overview</h6>
            <div class="card w-90">
                <div class="card-body">
                    <h5 class="card-title">Description</h5>
                    <p class="card-text">@Model.GridSpace.Description</p>
                </div>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item">Row: @Model.GridSpace.Row</li>
                    <li class="list-group-item">Column: @Model.GridSpace.Col</li>
                    <li class="list-group-item">Encounters: @Model.GridEncounters.Count()</li>
                    <li class="list-group-item">Characters: @Model.GridCharacters.Count()</li>
                    <li class="list-group-item">Accessible: <label class="switch">
                            <input onchange="UpdateAccessibility(@Model.GridSpace.Id)" type="checkbox"
                                   checked="@Model.GridSpace.Accessible"/>
                            <span class="slider round"></span>
                        </label></li>
                </ul>
            </div>
        </div>

        <div class="tab-pane" id="history">
            <div class="card" id="GridSpaceHistoryCard">
                <h5 class="card-title">History
                    <button class="rounded"><img src="~/images/Icons/pencil-fill.svg" width="16" height="16"
                                                 fill="currentColor" class="bi bi-pencil-fill"/></button>
                </h5>
                <div class="card-body">@Model.GridSpace.History</div>

            </div>

            <form id="GridSpaceHistoryForm" class="">
                <input value="@Model.GridSpace.History" type="text" id="GridSpaceHistoryInput">

                <button onclick="UpdateHistory(@Model.GridSpace.Id)">Save</button>
            </form>
        </div>


        <div class="tab-pane" id="notes">
            <div class="card" id="GridSpaceNotesCard">
                <h5 class="card-title">Notes
                    <button class="rounded"><img src="~/images/Icons/pencil-fill.svg" width="16" height="16"
                                                 fill="currentColor" class="bi bi-pencil-fill"/></button>
                </h5>
                <div class="card-body">@Model.GridSpace.Notes</div>

            </div>

            <form id="GridSpaceNotesForm" class="">
                <input type="text" id="GridSpaceNotesInput" value="@Model.GridSpace.Notes">

                <button onclick="UpdateNotes(@Model.GridSpace.Id)">Save</button>
            </form>
        </div>

        <div class="tab-pane" id="encounters">
            <div class="container">
                <div class="card-group">
                    @foreach (var encounter in @Model.GridEncounters)
                    {
                        <div class="card" style="width: 18rem;">
                            <div class="card-body">
                                <h5 class="card-title">@encounter.Item2.Name</h5>
                                <p class="card-text">@encounter.Item2.Description</p>
                                <ul class="list-group list-group-flush">
                                    <li class="list-group-item">
                                        Completed:
                                        <label class="switch">
                                            <input onchange="UpdateCompletedStatus(@encounter.Item1.Id)" type="checkbox"
                                                   checked="@encounter.Item1.IsCompleted"/>
                                            <span class="slider round"></span>
                                        </label>
                                    </li>
                                </ul>

                                <button onclick="RemoveGridEncounter(@encounter.Item1.Id)" class="card-link">Remove
                                </button>
                            </div>
                        </div>
                    }
                </div>
                <form>
                    <select class="form-control" id="encounterSelectionElement" required="required">
                        <option value="">Select Encounter</option>
                        @foreach (var encounter in @Model.Encounters)
                        {
                            <option value="@encounter.Id">@encounter.Name</option>
                        }

                    </select>
                    <button onclick="AddEncounter(@Model.GridSpace.Id)">Add Encounter</button>
                </form>

            </div>
        </div>
        <div class="tab-pane" id="characters">
            <div class="container">
                <div class="card-group">
                    @foreach (var character in @Model.GridCharacters)
                    {
                        <div class="card" style="width: 18rem;">
                            <div class="card-body">
                                <h5 class="card-title">@character.Item2.Name</h5>
                                <p class="card-text">@character.Item2.Description</p>

                                <button onclick="RemoveGridCharacter(@character.Item1.Id)" class="card-link">Remove
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
            <form>
                <select class="form-control" id="characterSelectionElement" required="required">
                    <option value="">Select Character</option>
                    @foreach (var character in @Model.Characters)
                    {
                        <option value="@character.Id">@character.Name</option>
                    }

                </select>

                <button onclick="AddCharacter(@Model.GridSpace.Id)">Add Character</button>
            </form>

        </div>
    </div>
</div>
<div class="modal-footer">
    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
</div>

<script type="text/javascript">
    function AddEncounter(id) {
        const encounterId = $('#encounterSelectionElement').val();
        $.ajax({
            url: "/GridSpace/AddEncounterToGridSpace/",
            type: 'POST',
            data: {gridSpaceId: id, encounterId: encounterId},
            success: function (data) {
                alert("Encounter added to Grid!");
            },
            error: function () {
                alert("Error loading content.");
            }
        });
    }

    function AddCharacter(id) {
        const characterId = $('#characterSelectionElement').val();
        $.ajax({
            url: "/GridSpace/AddCharacterToGridSpace/",
            type: 'POST',
            data: {gridSpaceId: id, characterId: characterId},
            success: function (data) {
                alert("Character added to Grid!");
            },
            error: function () {
                alert("Error loading content.");
            }
        });
    }

    function UpdateAccessibility(id) {
        $.ajax({
            url: "/GridSpace/UpdateAccessibility/",
            type: 'POST',
            data: {gridSpaceId: id},
            success: function (data) {
                alert("Accessibility Updated!");
            },
            error: function () {
                alert("Error loading content.");
            }
        });
    }

    function UpdateHistory(id) {
        const updatedHistory = $('#GridSpaceHistoryInput').val();
        $.ajax({
            url: "/GridSpace/UpdateHistory/",
            type: 'POST',
            data: {gridSpaceId: id, updatedHistory: updatedHistory},
            success: function (data) {

            },
            error: function () {
                alert("Error loading content.");
            }
        });


    }

    function UpdateNotes(id) {
        const updatedNotes = $('#GridSpaceNotesInput').val();
        $.ajax({
            url: "/GridSpace/UpdateNotes/",
            type: 'POST',
            data: {gridSpaceId: id, updatedNotes: updatedNotes},
            success: function (data) {

            },
            error: function () {
                alert("Error loading content.");
            }
        });

    }

    function UpdateCompletedStatus(id) {
        $.ajax({
            url: "/GridSpace/UpdateGridEncounterCompletedStatus/",
            type: 'POST',
            data: {gridEncounterId: id},
            success: function (data) {
                alert(data)
            },
            error: function () {
                alert("Error loading content.");
            }
        });

    }

    function RemoveGridEncounter(id) {
        $.ajax({
            url: "/GridSpace/RemoveGridEncounterFromGridSpace/",
            type: 'POST',
            data: {gridEncounterId: id},
            success: function (data) {
                alert("Grid Encounter Removed")
            },
            error: function () {
                alert("Error removing Grid Encounter.")
            }
        });
    }

    function RemoveGridCharacter(id) {
        $.ajax({
            url: "/GridSpace/RemoveGridCharacterFromGridSpace/",
            type: 'POST',
            data: {gridCharacterId: id},
            success: function (data) {
                alert("Grid Character Removed")
            },
            error: function () {
                alert("Error removing Grid Character.")
            }
        });
    }
</script>